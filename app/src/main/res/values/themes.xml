<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyTodoApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.MyTodoApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorAccent">@color/blue</item>
        <item name="mainThemeColor">@color/blue</item>
        <item name="mainThemeLight">#dbe9f5</item>
        <item name="navGradientStart">#E3F2FD</item>
        <item name="appLogo">@drawable/icon</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.MyTodoApp.Pink" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorAccent">@color/pink_theme</item>
        <item name="mainThemeColor">@color/pink_theme</item>
        <item name="mainThemeLight">#ffdede</item>
        <item name="navGradientStart">#FFF1F1</item>
        <item name="appLogo">@drawable/logo_pink</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="CircleImageStyle">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Theme cho CalendarView -->
    <style name="CustomCalendarTheme" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">?attr/mainThemeColor</item>
        <item name="android:headerBackground">?attr/mainThemeColor</item>
        <item name="colorAccent">?attr/mainThemeColor</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/BlackButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/BlackButtonStyle</item>
    </style>

    <style name="BlackButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="CustomCalendarDate">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CustomTodayDate" parent="CustomCalendarDate">
        <item name="android:textColor">?attr/mainThemeColor</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomCalendarWeek">
        <item name="android:textColor">?attr/mainThemeColor</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalendarDayHeader">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icon</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="postSplashScreenTheme">@style/Theme.MyTodoApp</item>
    </style>

    <style name="Theme.App.Starting.Pink" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/pink_theme</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_pink</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="postSplashScreenTheme">@style/Theme.MyTodoApp.Pink</item>
    </style>

    <style name="DayCircleStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/bg_repeat_day_circle_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">12sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>