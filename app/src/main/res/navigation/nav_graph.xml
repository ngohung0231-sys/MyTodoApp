<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.hungday.mytodoapp.fragment.OnboardingFragment"
        android:label="Onboarding"
        app:navGraph="@navigation/nav_graph"
        tools:layout="@layout/fragment_onboarding">
            <action
                android:id="@+id/action_onboarding_to_setupProfile"
                app:destination="@id/setupProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/setupProfileFragment"
        android:name="com.hungday.mytodoapp.fragment.SetupProfileFragment"
        android:label="Setup Profile"
        tools:layout="@layout/fragment_setup_profile">
        <action
            android:id="@+id/action_setupProfile_to_homeFragment"
            app:destination="@+id/homeFragment"/>
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.hungday.mytodoapp.fragment.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home"/>

</navigation>