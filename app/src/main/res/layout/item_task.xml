<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/taskView"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <CheckBox
        android:id="@+id/cbTaskStatus"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:button="@null"
        android:background="@drawable/cb_custom_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTaskTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:textColor="@color/black"
        android:text="@string/task_title"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/cbTaskStatus"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/tvTaskTitle"
        app:layout_constraintStart_toEndOf="@+id/cbTaskStatus"
        app:layout_constraintTop_toBottomOf="@+id/tvTaskTitle">

        <ImageView
            android:id="@+id/imgClock"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/clock"
            app:tint="#6b6f72"
            app:srcCompat="@drawable/clock" />

        <TextView
            android:id="@+id/tvTaskTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="10dp"
            android:text="@string/_09_00_am"
            android:textColor="#6b6f72"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/imgNotifyBell"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/notification"
            app:tint="#6b6f72"
            app:srcCompat="@drawable/bell_click" />

        <ImageView
            android:id="@+id/imgPriorityIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@string/priority"
            android:src="@drawable/ic_tag"
            android:layout_gravity="center"
            app:tint="#ee4d5e" />

        <TextView
            android:id="@+id/tvPriorityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/high"
            android:textColor="#ee4d5e"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>