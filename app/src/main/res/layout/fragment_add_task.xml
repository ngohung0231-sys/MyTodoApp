<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="10dp"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/btn_click_scale"
                android:foreground="@drawable/ripple_rounded_bg"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/add_task"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:layout_weight="1"
                android:textStyle="bold"
                android:gravity="center"/>

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#ced8dd"/>

        <EditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            android:hint="@string/what_needs_to_be_done"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:background="@drawable/bg_grey"

            android:paddingVertical="12dp"/>

        <LinearLayout
            android:id="@+id/rowSetPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_grey"
            android:foreground="@drawable/ripple_rounded_bg"
            android:stateListAnimator="@animator/btn_click_scale"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/icPriority"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_tag"
                    app:tint="#4a93ce"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/priority"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSelectedPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/low"
                    android:textColor="#A0A0A0"
                    android:layout_marginEnd="16dp"/>

                <ImageView
                    android:id="@+id/chevronPriority"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_chevron_down"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandableSetPriority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="visible"
                android:padding="12dp">

                <TextView
                    android:id="@+id/btnLow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:paddingVertical="3dp"
                    android:text="@string/low"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:background="@drawable/bg_priority_low"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg" />

                <TextView
                    android:id="@+id/btnMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:paddingVertical="3dp"
                    android:text="@string/medium"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue"
                    android:background="@drawable/bg_priority_medium"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg" />

                <TextView
                    android:id="@+id/btnHigh"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingVertical="3dp"
                    android:text="@string/high"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/red"
                    android:background="@drawable/bg_priority_high"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSelectFolder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_grey"
            android:foreground="@drawable/ripple_rounded_bg"
            android:stateListAnimator="@animator/btn_click_scale"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/icFolder"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_folder"
                    app:tint="#4a93ce"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/select_folder"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSelectedFolder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/others"
                    android:textColor="#A0A0A0"
                    android:layout_marginEnd="16dp"/>

                <ImageView
                    android:id="@+id/chevronFolder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_chevron_down"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandableSelectFolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFolders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    tools:listitem="@layout/item_folder_add_task"/>

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSetDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_grey"
            android:foreground="@drawable/ripple_rounded_bg"
            android:stateListAnimator="@animator/btn_click_scale"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/icCalendar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#4a93ce"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="@string/set_date_amp_time"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A0A0A0"
                    android:layout_marginEnd="16dp"/>

                <ImageView
                    android:id="@+id/chevronDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_chevron_down"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/expandableSetDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <CalendarView
                    android:id="@+id/calendarView"
                    android:layout_width="match_parent"
                    android:layout_height="310dp"
                    android:theme="@style/CustomCalendarTheme"
                    android:dateTextAppearance="@style/CustomCalendarDate"
                    android:weekDayTextAppearance="@style/CustomCalendarWeek"
                    android:firstDayOfWeek="2" />

                <TimePicker
                    android:id="@+id/timePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:timePickerMode="spinner" />
            </LinearLayout>
        </LinearLayout>

    <LinearLayout
        android:id="@+id/rowAddNoti"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="16dp"
        android:stateListAnimator="@animator/btn_click_scale"
        android:background="@drawable/bg_grey"
        android:foreground="@drawable/ripple_rounded_bg"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/icNotification"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/bell"
                app:tint="@color/blue"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="@string/add_notification"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvNotiSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/off"
                android:textColor="#A0A0A0"
                android:layout_marginEnd="16dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAddNoti"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumb="@drawable/switch_thumb"
                app:track="@drawable/switch_track"
                app:switchMinWidth="52dp"
                app:thumbTint="@null"
                app:trackTint="@null"
                android:clickable="true"
                android:focusable="true"
                android:elevation="0dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/expandableAddNoti"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remind_me_before"
                android:textColor="#707070"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/btnNotiAtTime"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:text="@string/at_time_of_task"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_noti_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg"/>

                <TextView
                    android:id="@+id/btnNoti10Min"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/_10_minutes_before"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_noti_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnNoti30Min"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:gravity="center"
                    android:text="@string/_30_minutes_before"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_noti_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg"/>

                <TextView
                    android:id="@+id/btnNoti1Hour"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/_1_hour_before"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_noti_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/btn_click_scale"
                    android:foreground="@drawable/ripple_rounded_bg"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
        <Button
            android:id="@+id/btnAddTask"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="#4a93ce"
            android:text="@string/add_task"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>